<?xml version="1.0" encoding="utf-8"?>
<!-- Small Widget: بطاقة التاريخ الهجري فقط — مطابق لـ iOS SmallWidgetView -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_outer_bg"
    android:padding="8dp">

    <!-- بطاقة التاريخ الهجري الداخلية -->
    <LinearLayout
        android:id="@+id/hijri_card"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="18dp"
        android:background="@drawable/widget_hijri_card_bg"
        android:gravity="center"
        android:orientation="vertical">

        <!-- FrameLayout لتراكب مخطوطة الشهر + رقم اليوم -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp">

            <!-- رقم اليوم الهجري — كبير وشفاف خلف المخطوطة -->
            <TextView
                android:id="@+id/hijri_day_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|top"
                android:alpha="0.4"
                android:textColor="#DDA15E"
                android:textSize="42sp"
                android:textStyle="bold" />

            <!-- مخطوطة الشهر الهجري -->
            <ImageView
                android:id="@+id/hijri_month_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:contentDescription="@string/hijri_widget_name"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:visibility="gone" />

            <!-- اسم الشهر (نص احتياطي) -->
            <TextView
                android:id="@+id/hijri_month_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/kufi"
                android:textColor="#283618"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- التاريخ الميلادي + السنة الهجرية -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/gregorian_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#DDA15E"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:text="•"
                android:textColor="#DDA15E"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/hijri_year_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#DDA15E"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- شعار القرآن الكريم -->
    <ImageView
        android:id="@+id/quran_logo"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_gravity="center_horizontal|bottom"
        android:scaleType="fitCenter"
        android:src="@drawable/quran_logo"
        android:contentDescription="@string/hijri_widget_name" />

</FrameLayout>
